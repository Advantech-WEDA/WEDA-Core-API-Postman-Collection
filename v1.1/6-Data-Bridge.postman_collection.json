      "item": [
        {
          "name": "Create MQTT Broker Config",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('created', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const body = pm.response.json();",
                  "if (body && body.mqttConfigId) { pm.environment.set('mqttConfigId', body.mqttConfigId); }"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"mqtt local\",\n  \"brokerEndpoint\": \"localhost:1883\",\n  \"authType\": \"UsernamePassword\",\n  \"brokerCredentials\": {\n    \"username\": \"user\",\n    \"password\": \"pass\"\n  },\n  \"keepAliveInterval\": \"60s\",\n  \"reconnectInterval\": \"5s\",\n  \"mqttProtocolVersion\": \"V311\",\n  \"checkConnection\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
