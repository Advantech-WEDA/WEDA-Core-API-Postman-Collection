    {
      "name": "Client-Cred Create",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var response = pm.response.json();",
              "",
              "if (response.clientId) {",
              "    pm.environment.set(\"clientId\", response.clientId);",
              "}",
              "if (response.clientSecret) {",
              "    pm.environment.set(\"clientSecret\", response.clientSecret);",
              "}",
              "if (response.clientCredentialId) {",
              "    pm.environment.set(\"clientCredentialId\", response.clientSecret);",
              "}",
              "",
              ""
