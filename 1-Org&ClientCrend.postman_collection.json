  "item": [
    {
      "name": "Org List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.expect(pm.response.code).to.eql(200));",
              "const responseJson = pm.response.json();",
              "const orgs = responseJson.items;",
              "const login = pm.environment.get('login');",
              "const org = orgs.find(o => o.name === login);",
              "if (org) {",
              "    pm.environment.set('org_id', org.orgId);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
