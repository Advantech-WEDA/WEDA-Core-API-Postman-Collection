      "name": "Devices",
      "item": [
        {
          "name": "Node Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function randomString(length) {",
                  "    // You can customize the character set here",
                  "    var chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';",
                  "    var result = '';",
                  "    for (var i = 0; i < length; i++) {",
                  "        result += chars.charAt(Math.floor(Math.random() * chars.length));",
                  "    }",
                  "    return result;",
                  "}",
                  "",
                  "// Set the desired length (e.g., 10 characters)",
                  "const STRING_LEN = 12;",
                  "",
                  "// Set the generated string as a collection or environment variable",
                  "// Use pm.variables.set for a local variable, or pm.collectionVariables.set/pm.environment.set",
                  "// pm.environment.set('deviceId', randomString(STRING_LEN));",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"{{deviceId}}\",\n  \"hwModel\": \"{{deviceModel}}\",\n  \"deviceName\": \"{{deviceModel}}-{{deviceId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{apibaseurl}}/orgs/{{org_id}}/devices",
              "host": [
                "{{apibaseurl}}"
              ],
              "path": [
                "orgs",
                "{{org_id}}",
                "devices"
              ]
            }
          },
          "response": []
        },
