    {
      "name": "DataSource+DataObjects",
      "item": [
        {
          "name": "Get device data source definitions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{apibaseurl}}/devices/{{deviceId}}/data-source",
              "host": [
                "{{apibaseurl}}"
              ],
              "path": [
                "devices",
                "{{deviceId}}",
                "data-source"
              ]
            },
            "description": "Retrieve data source definitions for the specified device, containing all sensors paired with their schema definitions."
          },
          "response": []
        },
        {
          "name": "Get device data objects",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{apibaseurl}}/devices/{{deviceId}}/data-objects?skipCount=0&maxResultCount=10",
              "host": [
                "{{apibaseurl}}"
              ],
              "path": [
                "devices",
                "{{deviceId}}",
                "data-objects"
              ],
              "query": [
                {
                  "key": "skipCount",
                  "value": "0"
                },
                {
                  "key": "maxResultCount",
                  "value": "10"
                }
              ]
            },
            "description": "Retrieve the paged list of data objects (synchronized sensor definitions) for the specified device."
          },
          "response": []
        },
        {
          "name": "Get data object by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{apibaseurl}}/devices/{{deviceId}}/data-objects/{{dataObjectId}}",
              "host": [
                "{{apibaseurl}}"
              ],
              "path": [
                "devices",
                "{{deviceId}}",
                "data-objects",
                "{{dataObjectId}}"
              ]
            },
            "description": "Retrieve a single data object by its unique identifier for the specified device."
          },
          "response": []
        }
      ]
