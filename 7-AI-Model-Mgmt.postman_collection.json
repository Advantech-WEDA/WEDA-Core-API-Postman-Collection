  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          "// Generate a unique model name + edition once per run so create never collides",
          "// (avoids the AppAiModels unique-name constraint, incl. soft-deleted ghosts) and",
          "// the whole flow is re-runnable.",
          "if (!pm.collectionVariables.get('runStamp')) {",
          "    var t = String(Date.now());",
          "    pm.collectionVariables.set('runStamp', t);",
          "    pm.collectionVariables.set('modelEdition', '1.0.' + t);",
          "    var base = (pm.collectionVariables.get('modelName') || 'postman-flow-test').replace(/-\\d{10,}$/, '');",
          "    pm.collectionVariables.set('modelName', base + '-' + t);",
          "    console.log('Run model =', pm.collectionVariables.get('modelName'), '| edition =', pm.collectionVariables.get('modelEdition'));",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    }
